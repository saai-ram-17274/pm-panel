# Zoho Mail OAuth (self-client refresh-token grant)
# Sample values — overwrite with your own from https://api-console.zoho.in/
ZOHO_MAIL_CLIENT_ID=
ZOHO_MAIL_CLIENT_SECRET=
ZOHO_MAIL_REFRESH_TOKEN=
ZOHO_MAIL_ACCOUNT_ID=
ZOHO_MAIL_FROM=

# Comma-separated list of recipients for the 21:00 IST daily digest
ZOHO_MAIL_DAILY_TO=

# Comma-separated allow-list of domains the chatbot's send_chat_transcript
# tool may send to. Leave blank to auto-derive from ZOHO_MAIL_DAILY_TO and
# ZOHO_MAIL_FROM (recommended for most setups).
# MAIL_ALLOWED_DOMAINS=zohocorp.com,zohomail.in

# Optional region overrides (default to .in DC)
# ZOHO_ACCOUNTS_BASE=https://accounts.zoho.in
# ZOHO_MAIL_API_BASE=https://mail.zoho.in/api
